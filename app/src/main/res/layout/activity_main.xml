<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:orientation="horizontal"
        android:background="#16213e"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="铁塔运维助手"
            android:textColor="#e94560"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvUserInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="未登录"
            android:textColor="#a0a0c0"
            android:textSize="11sp"
            android:gravity="end"
            android:layout_marginEnd="6dp"/>

        <TextView
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:text="退出"
            android:textColor="#e94560"
            android:textSize="11sp"
            android:background="@drawable/bg_tag"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- 配置区 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0f3460"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- 第1行：三个CheckBox + 轮询区间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <CheckBox
                android:id="@+id/cbAutoFeedback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动反馈"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:buttonTint="#e94560"
                android:paddingStart="2dp"
                android:checked="true"/>

            <CheckBox
                android:id="@+id/cbAutoAccept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动接单"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:buttonTint="#e94560"
                android:paddingStart="2dp"
                android:layout_marginStart="4dp"
                android:checked="true"/>

            <CheckBox
                android:id="@+id/cbAutoRevert"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自动回单"
                android:textColor="#ffffff"
                android:textSize="13sp"
                android:buttonTint="#e94560"
                android:paddingStart="2dp"
                android:layout_marginStart="4dp"
                android:checked="false"/>

            <!-- 弹簧：把轮询区间推到右边 -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="轮询(秒):"
                android:textColor="#a0a0c0"
                android:textSize="11sp"/>
            <EditText
                android:id="@+id/etIntervalMin"
                android:layout_width="36dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_input"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="90"
                android:textColor="#000000"
                android:textSize="11sp"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="#a0a0c0"
                android:textSize="11sp"/>
            <EditText
                android:id="@+id/etIntervalMax"
                android:layout_width="36dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_input"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="120"
                android:textColor="#000000"
                android:textSize="11sp"
                android:inputType="number"
                android:gravity="center"/>
        </LinearLayout>

        <!-- 第2行：反馈阈值 + 接单阈值 + 开始监控 + 停止 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="反馈(分):"
                android:textColor="#a0a0c0"
                android:textSize="11sp"/>
            <EditText
                android:id="@+id/etFeedbackMin"
                android:layout_width="36dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_input"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="70"
                android:textColor="#000000"
                android:textSize="11sp"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="#a0a0c0"
                android:textSize="11sp"/>
            <EditText
                android:id="@+id/etFeedbackMax"
                android:layout_width="36dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_input"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="90"
                android:textColor="#000000"
                android:textSize="11sp"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="接单:"
                android:textColor="#a0a0c0"
                android:textSize="11sp"/>
            <EditText
                android:id="@+id/etAcceptMin"
                android:layout_width="36dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_input"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="60"
                android:textColor="#000000"
                android:textSize="11sp"
                android:inputType="number"
                android:gravity="center"
                android:layout_marginStart="3dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="~"
                android:textColor="#a0a0c0"
                android:textSize="11sp"/>
            <EditText
                android:id="@+id/etAcceptMax"
                android:layout_width="36dp"
                android:layout_height="26dp"
                android:background="@drawable/bg_input"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:text="90"
                android:textColor="#000000"
                android:textSize="11sp"
                android:inputType="number"
                android:gravity="center"/>

            <!-- 弹簧：把按钮推到右边 -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnStartMonitor"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="开始监控"
                android:textSize="11sp"
                android:background="@drawable/bg_btn_primary"
                android:textColor="#ffffff"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="4dp"
                android:layout_marginTop="-2dp"/>

            <Button
                android:id="@+id/btnStopMonitor"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:text="停止"
                android:textSize="11sp"
                android:background="@drawable/bg_btn_secondary"
                android:textColor="#ffffff"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp"
                android:layout_marginTop="-2dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- 进度条 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#0a0a1a"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="就绪"
            android:textColor="#a0a0c0"
            android:textSize="11sp"/>

        <TextView
            android:id="@+id/tvNextRun"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#606080"
            android:textSize="10sp"/>
    </LinearLayout>

    <!-- 排序工具栏（HorizontalScrollView防止按钮被挤出屏幕） -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#0d0d20"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="排序："
                android:textColor="#606080"
                android:textSize="11sp"/>

            <!-- 工单历时排序按钮（点击在大→小/小→大之间切换） -->
            <TextView
                android:id="@+id/btnSortBillTime"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="工单历时 ↓"
                android:textSize="11sp"
                android:textColor="#ffffff"
                android:background="@drawable/bg_tag"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="4dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 反馈历时排序按钮（点击在大→小/小→大之间切换） -->
            <TextView
                android:id="@+id/btnSortFeedbackTime"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="反馈历时 ↕"
                android:textSize="11sp"
                android:textColor="#a0a0c0"
                android:background="@drawable/bg_tag"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 告警时间排序按钮（点击在最新→最旧/最旧→最新之间切换） -->
            <TextView
                android:id="@+id/btnSortAlertTime"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="告警时间 ↕"
                android:textSize="11sp"
                android:textColor="#a0a0c0"
                android:background="@drawable/bg_tag"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <!-- 告警状态排序按钮（点击在告警中优先/已恢复优先之间切换） -->
            <TextView
                android:id="@+id/btnSortAlertStatus"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:text="告警状态 ↕"
                android:textSize="11sp"
                android:textColor="#a0a0c0"
                android:background="@drawable/bg_tag"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/tvSortDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="工单历时 大→小"
                android:textColor="#404060"
                android:textSize="10sp"
                android:layout_marginStart="8dp"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- 工单列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerOrders"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#12122a"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

</LinearLayout>
